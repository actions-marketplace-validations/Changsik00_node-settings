# .env sample for APP_ENV=stage
#
# Pre-production environment that mirrors prod. Same shape as
# .env.prod.sample; use it to catch config drift before promotion.
#
# Per-env config that resolves at runtime (from settings.config.ts):
#   bucket: stage-bucket
#   workerConcurrency: 1
#   featureFlags.newCheckout: false

APP_ENV=stage
PORT=8080
DB_HOST=stage-db.internal
REDIS_URL=redis://stage-redis.internal:6379

# --- Secrets ---

# Pulled from the secret manager at pod start.
DB_PASSWORD=
