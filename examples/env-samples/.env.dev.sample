# .env sample for APP_ENV=dev
#
# Use this in the dev cluster (or for staging-like environments). Real
# secrets should come from your secret manager — this file is a template
# only, do not commit real values.
#
# Per-env config that resolves at runtime (from settings.config.ts):
#   bucket: dev-bucket
#   workerConcurrency: 1
#   featureFlags.newCheckout: false

APP_ENV=dev
PORT=8080
DB_HOST=dev-db.internal
REDIS_URL=redis://dev-redis.internal:6379

# --- Secrets ---

# Injected at deploy time from your secret manager (Vault, AWS SM, ...).
DB_PASSWORD=
