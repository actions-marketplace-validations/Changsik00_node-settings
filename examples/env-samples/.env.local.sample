# .env sample for APP_ENV=local
#
# Use this as a template for local development. Copy to .env.local
# (or .env) at the project root, fill in the blanks, and dotenv-load
# it before calling settings(process.env).
#
# Per-env config that resolves at runtime (from settings.config.ts):
#   bucket: local-bucket
#   workerConcurrency: 1
#   featureFlags.newCheckout: false

APP_ENV=local
PORT=3000
DB_HOST=localhost
REDIS_URL=redis://localhost:6379

# Override layer for ad-hoc local tweaks (optional, JSON).
# CONFIG_OVERRIDE_JSON={"workerConcurrency":2}

# --- Secrets ---

# Local dev password — never reuse this anywhere else.
DB_PASSWORD=local-dev-password
