# .env sample for APP_ENV=prod
#
# Production. NEVER commit real values; this is a *template*. Real
# secrets are injected at runtime by your platform (Sealed Secrets,
# External Secrets Operator, Vault, AWS Secrets Manager, GCP Secret
# Manager, etc.).
#
# Per-env config that resolves at runtime (from settings.config.ts):
#   bucket: prod-bucket
#   workerConcurrency: 8
#   featureFlags.newCheckout: true

APP_ENV=prod
PORT=8080
DB_HOST=prod-db.internal
REDIS_URL=redis://prod-redis.internal:6379

# --- Secrets ---

# Provided by the secret manager. Do not commit a value here.
DB_PASSWORD=
