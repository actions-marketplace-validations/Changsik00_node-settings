# Base .env — values shared across every environment. Committed.
# Each .env.<mode> file below this layers on top via loadDotenvCascade.
#
# Convention reminder for YOUR project:
#   - .env, .env.<mode>           → committed (no secrets)
#   - .env.local, .env.<mode>.local → gitignored (developer overrides)
#   - real secrets                → injected by CI / Vault / K8s Secret
#                                   (NEVER committed, ever)

PORT=3000
