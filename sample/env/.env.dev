# .env.dev — dev environment (CI deploy target).
# Non-secret values are committed; secrets (DB_PASSWORD, SENTRY_DSN)
# are injected by your CI / orchestrator at deploy time and override
# whatever's here.

APP_ENV=dev
DB_HOST=db.dev.internal
DB_PASSWORD=REPLACE_VIA_CI
REDIS_URL=redis://redis.dev.internal:6379
# SENTRY_DSN is also injected by CI; leave it out of source.
