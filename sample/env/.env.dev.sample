# .env.dev — for the dev environment.
# Real secrets come from your secret manager; this file is a template.
#
# Layered config that resolves at runtime (sample/config/dev.ts):
#   bucket: dev-bucket
#   featureFlags.experimentalSearch: true

APP_ENV=dev
PORT=8080
DB_HOST=dev-db.internal
REDIS_URL=redis://dev-redis.internal:6379

# --- Secrets (injected by the deploy platform) ---
DB_PASSWORD=
SENTRY_DSN=
