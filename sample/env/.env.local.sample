# .env.local — drop the .sample suffix and put it at the project root.
# loadDotenvCascade() picks it up automatically when APP_ENV=local.
#
# Layered config that resolves at runtime (sample/config/local.ts):
#   bucket: local-bucket
#   logLevel: debug
#   rateLimits.perUserRequestsPerMinute: 1000

APP_ENV=local
PORT=3000
DB_HOST=localhost
REDIS_URL=redis://localhost:6379

# --- Secrets ---
DB_PASSWORD=local-dev-password
