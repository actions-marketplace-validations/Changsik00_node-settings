# .env.prod — production.
# NEVER commit real values. Real secrets come from Sealed Secrets,
# External Secrets Operator, Vault, AWS / GCP Secret Manager, etc.
#
# Layered config (sample/config/prod.ts):
#   bucket: prod-bucket
#   workerConcurrency: 8
#   featureFlags.newCheckout: true
#   rateLimits.perUserRequestsPerMinute: 120

APP_ENV=prod
PORT=8080
DB_HOST=prod-db.internal
REDIS_URL=redis://prod-redis.internal:6379

# --- Secrets ---
DB_PASSWORD=
SENTRY_DSN=
