# .env.stage — pre-production environment.
# Mirrors prod; use it to catch config drift before promotion.
#
# Layered config (sample/config/stage.ts):
#   bucket: stage-bucket
#   workerConcurrency: 4

APP_ENV=stage
PORT=8080
DB_HOST=stage-db.internal
REDIS_URL=redis://stage-redis.internal:6379

# --- Secrets ---
DB_PASSWORD=
SENTRY_DSN=
