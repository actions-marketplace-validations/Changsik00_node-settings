# .env.prod — production environment.
# Real production secrets NEVER live in this file. The convention is:
#   - this file is gitignored in your real project
#   - hostnames / non-secret URLs may be committed
#   - DB_PASSWORD, SENTRY_DSN, JWT keys, etc. come from Vault / K8s Secret
#     / GitHub Actions secrets / Doppler / SOPS — pick your tool.

APP_ENV=prod
DB_HOST=db.prod.internal
DB_PASSWORD=REPLACE_VIA_VAULT
# REDIS_URL is optional in this schema; production might not need it.
