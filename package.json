{
  "name": "@changsik00/node-settings",
  "version": "0.10.0",
  "description": "Schema-first settings for Node apps: zod env validation + per-env layering + .env.example / Markdown docs / Kubernetes manifest generation, with a CLI for CI/CD validation.",
  "keywords": [
    "config",
    "configuration",
    "settings",
    "env",
    "dotenv",
    "zod",
    "schema",
    "validation",
    "kubernetes",
    "configmap",
    "secret",
    "12factor",
    "build-once-deploy-many"
  ],
  "license": "MIT",
  "author": "Changsik00 <lowmans00@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Changsik00/node-settings.git"
  },
  "bugs": {
    "url": "https://github.com/Changsik00/node-settings/issues"
  },
  "homepage": "https://github.com/Changsik00/node-settings#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "default": "./dist/generators/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "bin": {
    "node-settings": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc -b tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:sample": "node dist/cli/bin.js inspect --config sample/settings.ts > /dev/null && node dist/cli/bin.js inspect --config sample/settings.ts --env=prod > /dev/null",
    "verify:api": "node scripts/verify-api.mjs",
    "verify:docs": "node scripts/verify-docs.mjs",
    "verify": "pnpm run typecheck && pnpm run test:coverage && pnpm run build && pnpm run verify:dist && pnpm run verify:sample && pnpm run verify:api && pnpm run verify:docs && pnpm run verify:pack",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run verify:dist && pnpm run verify:api && pnpm run verify:pack"
  },
  "peerDependencies": {
    "vite": "^4 || ^5 || ^6 || ^7",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "jiti": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
