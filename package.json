{
  "name": "@env-kit/node-settings",
  "version": "0.12.0",
  "description": "Schema-first settings for Node apps: zod env validation + per-env layering + .env.example / Markdown docs / Kubernetes manifest generation, with a CLI for CI/CD validation.",
  "keywords": [
    "config",
    "configuration",
    "settings",
    "env",
    "dotenv",
    "zod",
    "schema",
    "validation",
    "kubernetes",
    "configmap",
    "secret",
    "12factor",
    "build-once-deploy-many"
  ],
  "license": "MIT",
  "author": "Changsik00 <lowmans00@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Changsik00/node-settings.git"
  },
  "bugs": {
    "url": "https://github.com/Changsik00/node-settings/issues"
  },
  "homepage": "https://github.com/Changsik00/node-settings#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "default": "./dist/generators/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild/index.d.ts",
      "default": "./dist/esbuild/index.js"
    }
  },
  "bin": {
    "node-settings": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); for (const f of fs.readdirSync('.')) if (f.endsWith('.tsbuildinfo')) fs.rmSync(f);\"",
    "dev": "tsc -b tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude 'src/cli/cli-e2e.test.ts' --exclude 'src/vite/**' --exclude 'src/next/**' --exclude 'src/esbuild/**' --exclude 'src/types.test.ts'",
    "test:integ": "vitest run src/vite src/next src/esbuild",
    "test:e2e": "vitest run src/cli/cli-e2e.test.ts",
    "test:contract": "vitest run src/types.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:sample": "node scripts/verify-sample.mjs",
    "verify:api": "node scripts/verify-api.mjs",
    "verify:docs": "node scripts/verify-docs.mjs",
    "verify:errors": "node scripts/verify-errors.mjs",
    "gen:errors-doc": "node scripts/generate-errors-doc.mjs",
    "mutation": "stryker run",
    "verify": "pnpm run typecheck && pnpm run test:coverage && pnpm run build && pnpm run verify:dist && pnpm run verify:sample && pnpm run verify:api && pnpm run verify:docs && pnpm run verify:errors && pnpm run verify:pack",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run verify:dist && pnpm run verify:api && pnpm run verify:pack"
  },
  "peerDependencies": {
    "esbuild": ">=0.21.0 <1.0.0",
    "next": "^13 || ^14 || ^15 || ^16",
    "vite": "^4 || ^5 || ^6 || ^7",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "jiti": "^2.4.0",
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "next": "^14.2.35",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
