exports[`generator snapshots > generatePerEnvExamples — every branch 1`] = `
{
  "dev": "# .env example for APP_ENV=dev
# Generated by @changsik00/node-settings.
# Required values are left blank — fill them in before booting the app.
#
# When this env loads, the layered config resolves to:
#   bucket: "dev-bucket"
#   region: "us-east-1"
#   workerConcurrency: 1

# APP_ENV (enum, optional, enum: local|dev|prod, default: "local")
APP_ENV=dev

# PORT (number, optional, default: 3000)
PORT=3000

# DB_HOST (string, required)
# Primary database host
DB_HOST=


# --- Secrets ---

# DB_PASSWORD (string, required, secret)
# Primary database password
DB_PASSWORD=

# SENTRY_DSN (string, optional, secret)
# Sentry DSN
SENTRY_DSN=
",
  "local": "# .env example for APP_ENV=local
# Generated by @changsik00/node-settings.
# Required values are left blank — fill them in before booting the app.
#
# When this env loads, the layered config resolves to:
#   bucket: "local-bucket"
#   region: "us-east-1"
#   workerConcurrency: 1

# APP_ENV (enum, optional, enum: local|dev|prod, default: "local")
APP_ENV=local

# PORT (number, optional, default: 3000)
PORT=3000

# DB_HOST (string, required)
# Primary database host
DB_HOST=


# --- Secrets ---

# DB_PASSWORD (string, required, secret)
# Primary database password
DB_PASSWORD=

# SENTRY_DSN (string, optional, secret)
# Sentry DSN
SENTRY_DSN=
",
  "prod": "# .env example for APP_ENV=prod
# Generated by @changsik00/node-settings.
# Required values are left blank — fill them in before booting the app.
#
# When this env loads, the layered config resolves to:
#   bucket: "prod-bucket"
#   region: "us-east-1"
#   workerConcurrency: 8

# APP_ENV (enum, optional, enum: local|dev|prod, default: "local")
APP_ENV=prod

# PORT (number, optional, default: 3000)
PORT=3000

# DB_HOST (string, required)
# Primary database host
DB_HOST=


# --- Secrets ---

# DB_PASSWORD (string, required, secret)
# Primary database password
DB_PASSWORD=

# SENTRY_DSN (string, optional, secret)
# Sentry DSN
SENTRY_DSN=
",
}
`;

