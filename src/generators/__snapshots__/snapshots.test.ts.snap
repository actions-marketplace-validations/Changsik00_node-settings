exports[`generator snapshots > generateK8sManifests — default (stringData secret) 1`] = `
{
  "configMap": "apiVersion: v1
kind: ConfigMap
metadata:
  name: demo-config
  namespace: prod
  labels:
    app: "demo"
data:
  APP_ENV: "local"
  PORT: "3000"
  # TODO: required, no default — provide before deploy
  # Primary database host
  DB_HOST: ""
",
  "secret": "apiVersion: v1
kind: Secret
metadata:
  name: demo-secret
  namespace: prod
  labels:
    app: "demo"
type: Opaque
stringData:
  # DB_PASSWORD (required)
  # Primary database password
  DB_PASSWORD: "REPLACE_ME"
  # SENTRY_DSN (optional)
  # Sentry DSN
  SENTRY_DSN: "REPLACE_ME"
",
  "yaml": "apiVersion: v1
kind: ConfigMap
metadata:
  name: demo-config
  namespace: prod
  labels:
    app: "demo"
data:
  APP_ENV: "local"
  PORT: "3000"
  # TODO: required, no default — provide before deploy
  # Primary database host
  DB_HOST: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: demo-secret
  namespace: prod
  labels:
    app: "demo"
type: Opaque
stringData:
  # DB_PASSWORD (required)
  # Primary database password
  DB_PASSWORD: "REPLACE_ME"
  # SENTRY_DSN (optional)
  # Sentry DSN
  SENTRY_DSN: "REPLACE_ME"
",
}
`;

exports[`generator snapshots > generateK8sManifests — inlineSecretValues (base64 data) 1`] = `
{
  "configMap": "apiVersion: v1
kind: ConfigMap
metadata:
  name: demo-config
data:
  APP_ENV: "local"
  PORT: "3000"
  # TODO: required, no default — provide before deploy
  # Primary database host
  DB_HOST: ""
",
  "secret": "apiVersion: v1
kind: Secret
metadata:
  name: demo-secret
type: Opaque
data:
  DB_PASSWORD: c3VwZXJzZWNyZXQ=
  SENTRY_DSN: aHR0cHM6Ly94QHkuaW8vMQ==
",
  "yaml": "apiVersion: v1
kind: ConfigMap
metadata:
  name: demo-config
data:
  APP_ENV: "local"
  PORT: "3000"
  # TODO: required, no default — provide before deploy
  # Primary database host
  DB_HOST: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: demo-secret
type: Opaque
data:
  DB_PASSWORD: c3VwZXJzZWNyZXQ=
  SENTRY_DSN: aHR0cHM6Ly94QHkuaW8vMQ==
",
}
`;

exports[`generator snapshots > generateMarkdownDocs — custom title + intro 1`] = `
"# demo-service env

Owned by team-platform.

| Key | Type | Required | Default | Secret | Description |
| --- | ---- | -------- | ------- | ------ | ----------- |
| \`APP_ENV\` | enum (\`local\` \\| \`dev\` \\| \`prod\`) | no | \`local\` | — |  |
| \`PORT\` | \`number\` | no | \`3000\` | — |  |
| \`DB_HOST\` | \`string\` | yes | — | — | Primary database host |
| \`DB_PASSWORD\` | \`string\` | yes | — | yes | Primary database password |
| \`SENTRY_DSN\` | \`string\` | no | — | yes | Sentry DSN |

_Generated by [@changsik00/node-settings](https://github.com/Changsik00/node-settings)._
"
`;

